#!/bin/sh
# Release runtime env. The shipped agent binary (`lapsus`) defaults to the live
# community coordinator; users can still override LAPSUS_COORDINATOR_URL.
# (Local dev via `mix lapsus.app` is unaffected — it keeps ws://localhost:4000.)
if [ "$RELEASE_NAME" = "lapsus" ]; then
  export LAPSUS_COORDINATOR_URL="${LAPSUS_COORDINATOR_URL:-wss://lapsus.pyrates.io}"
fi
