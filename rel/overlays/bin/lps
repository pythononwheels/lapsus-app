#!/bin/sh
# LAPSUS consumer CLI launcher.
# Forwards all args to LapsusAgent.CLI via the release node. Args are NUL-joined
# and base64-encoded into LPS_ARGV so prompts with spaces/quotes pass cleanly.

# Resolve symlinks (portable, works via ~/.local/bin/lps on Linux & macOS) so we
# find the release's own `lapsus` binary next to the real script.
self="$0"
while [ -L "$self" ]; do
  link="$(readlink "$self")"
  case "$link" in
    /*) self="$link" ;;
    *) self="$(dirname "$self")/$link" ;;
  esac
done
here="$(cd "$(dirname "$self")" && pwd)"

LPS_ARGV="$(printf '%s\0' "$@" | base64 | tr -d '\n')"
export LPS_ARGV
# `lps gateway` is a long-running server. Detach its stdin from the terminal so
# `lps gateway &` isn't SIGTTIN-stopped by job control (the BEAM otherwise tries to
# read the backgrounded tty). Interactive commands (ask/chat/picker) keep stdin.
if [ "$1" = "gateway" ]; then
  exec "$here/lapsus" eval 'LapsusAgent.CLI.main_from_env()' < /dev/null
else
  exec "$here/lapsus" eval 'LapsusAgent.CLI.main_from_env()'
fi
